APP_ENV=local
APP_NAME=GRC Platform
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

POSTGRES_DB=grc_platform
POSTGRES_USER=grc
POSTGRES_PASSWORD=grc_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://grc:grc_password@postgres:5432/grc_platform

REDIS_URL=redis://redis:6379/0

# Used to build the fixed OIDC redirect_uri and the post-SSO-login redirect
# target the SPA reads tokens from. See docs/security.md's SSO section.
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# AI provider abstraction (backend/app/modules/ai/providers.py).
# "echo" (default) needs no credentials and makes no network calls.
# Set to "openai", "azure_openai", or "ollama" to use a real provider.
AI_PROVIDER=echo
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
